---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import MemberCard from '@/components/MemberCard.astro';

const allMembers = await getCollection('members');
const allPosts = await getCollection('posts');

const membersData = await Promise.all(
  allMembers.map(async (member) => {
    const favCats = await Promise.all(
      (member.data.favoriteCategories ?? []).map((ref) => getEntry('categories', ref.id))
    );
    const visitCount = allPosts.filter((p) =>
      p.data.members.some((m) => m.id === member.id)
    ).length;
    return {
      id: member.id,
      name: member.data.name,
      bio: member.data.bio,
      image: member.data.image,
      favoriteCategories: favCats.filter(Boolean).map((c) => ({
        id: c!.id,
        label: c!.data.label,
        color: c!.data.color,
      })),
      visitCount,
    };
  })
);

membersData.sort((a, b) =>
  b.visitCount - a.visitCount || a.name.localeCompare(b.name, 'ko')
);

---

<BaseLayout title="멤버">
  <Header />
  <div class="bg-black text-white">
    <div class="max-w-6xl mx-auto px-6 py-10 md:py-16">
      <h1 class="text-4xl md:text-7xl font-black uppercase tracking-widest">MEMBERS</h1>
      <p class="mt-3 text-gray-400 text-lg">함께 탐방하는 소모임 멤버</p>
    </div>
  </div>
  <main class="max-w-6xl mx-auto px-6 py-10">
    <!-- Member grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {membersData.map((member) => (
        <MemberCard
          id={member.id}
          name={member.name}
          bio={member.bio}
          image={member.image}
          favoriteCategories={member.favoriteCategories}
          visitCount={member.visitCount}
        />
      ))}
    </div>
  </main>
</BaseLayout>
