---
import SojuGlassIcon from './SojuGlassIcon';

interface Props {
  rating: number;
  max?: number;
}

const { rating, max = 3 } = Astro.props;
---

<span class="inline-flex gap-1" aria-label={`평점 ${rating}/${max}`}>
  {
    Array.from({ length: max }, (_, i) => (
      <SojuGlassIcon
        filled={i < rating}
        className={i < rating ? 'text-accent' : 'text-gray-300'}
      />
    ))
  }
</span>
