---
import RatingIcon from './RatingIcon.astro';
import CategoryBadge from './CategoryBadge.astro';

interface CategoryData {
  id: string;
  label: string;
  color?: string;
}

interface Props {
  slug: string;
  title: string;
  date: Date;
  image: string;
  excerpt: string;
  rating: number;
  location: string;
  categories: CategoryData[];
  memberNames: string[];
}

const { slug, title, date, image, excerpt, rating, location, categories, memberNames } =
  Astro.props;

const formattedDate = date.toLocaleDateString('ko-KR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="group border-2 border-black bg-white hover:-translate-y-1 hover:shadow-xl transition-all duration-300">
  <a href={`/posts/${slug}`} class="block">
    <div class="overflow-hidden h-52 bg-gray-100">
      <img
        src={image}
        alt={title}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
        loading="lazy"
      />
    </div>
    <div class="p-5">
      <div class="flex flex-wrap gap-1.5 mb-3">
        {categories.map((cat) => <CategoryBadge label={cat.label} color={cat.color} />)}
      </div>
      <h3 class="text-xl font-bold leading-snug mb-2 group-hover:text-accent transition-colors duration-200">
        {title}
      </h3>
      <p class="text-sm text-gray-600 leading-relaxed mb-4 line-clamp-2">{excerpt}</p>
      <div class="flex items-center justify-between text-xs text-gray-500">
        <div class="flex items-center gap-2">
          <RatingIcon rating={rating} />
        </div>
        <time datetime={date.toISOString()}>{formattedDate}</time>
      </div>
      <div class="mt-3 pt-3 border-t border-gray-100 flex items-center gap-1.5 text-xs text-gray-500">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="shrink-0">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
        </svg>
        <span class="truncate">{location}</span>
      </div>
      {memberNames.length > 0 && (
        <div class="mt-2 flex items-center gap-1.5 text-xs text-gray-500">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="shrink-0">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" />
          </svg>
          <span class="flex flex-wrap gap-x-1">{memberNames.map((name, i) => (
            <span class="whitespace-nowrap">{name}{i < memberNames.length - 1 ? ',' : ''}</span>
          ))}</span>
        </div>
      )}
    </div>
  </a>
</article>
