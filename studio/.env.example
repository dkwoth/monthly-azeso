# Sanity Studio configuration. Copy this file to `.env` and fill in the values.
# These are project-specific and intentionally NOT committed.
SANITY_STUDIO_PROJECT_ID=
SANITY_STUDIO_DATASET=production
SANITY_STUDIO_TITLE=Monthly Azeso
# 배포 대상 앱 ID. `sanity deploy` 최초 성공 시 출력되는 appId를 넣으면
# 이후 배포 때 호스트네임/앱 선택을 묻지 않습니다. (비밀값 아님)
SANITY_STUDIO_DEPLOY_APP_ID=
